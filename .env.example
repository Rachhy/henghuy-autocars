DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
API_PORT=4001

# Admin account seeded via `npm run seed:admin`. Copy this file to .env and fill in.
ADMIN_NAME=Your Name
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=changeme1234

# Cloudflare R2 object storage. Leave blank to fall back to local disk uploads.
R2_PUBLIC_URL=
R2_BUCKET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
